<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Currency Exchange Converter</title>
        <css src="Suhas_CurrencyConverter::css/converter.css"/>
    </head>
    <body>
        <!-- Strip the entire header and footer on this page for a focused, standalone converter view. -->
        <referenceContainer name="header.container" remove="true"/>
        <referenceContainer name="footer-container" remove="true"/>
        <!-- Luma moves the copyright block out of the footer to before.body.end, so remove it by name. -->
        <referenceBlock name="copyright" remove="true"/>
        <referenceContainer name="content">
            <block class="Suhas\CurrencyConverter\Block\Converter"
                   name="currency.converter"
                   template="Suhas_CurrencyConverter::converter.phtml"/>
        </referenceContainer>
    </body>
</page>
